# ==========================================
# AI HUNAR PROJECT DATABASE
# ==========================================

# Local Database (SQLite by default)
AIHUNAR_LOCAL_DB_DIALECT=sqlite
AIHUNAR_LOCAL_DB_STORAGE=./data/aihunar_local.sqlite

# For MySQL/PostgreSQL local development (optional):
# AIHUNAR_LOCAL_DB_DIALECT=mysql
# AIHUNAR_LOCAL_DB_HOST=localhost
# AIHUNAR_LOCAL_DB_PORT=3306
# AIHUNAR_LOCAL_DB_NAME=aihunar_dev
# AIHUNAR_LOCAL_DB_USER=root
# AIHUNAR_LOCAL_DB_PASS=

# Production Database
AIHUNAR_PROD_DB_DIALECT=mysql
AIHUNAR_PROD_DB_HOST=your-prod-db-host.com
AIHUNAR_PROD_DB_PORT=3306
AIHUNAR_PROD_DB_NAME=aihunar_prod
AIHUNAR_PROD_DB_USER=aihunar_user
AIHUNAR_PROD_DB_PASS=your-secure-password

# ==========================================
# FFMPEG VIDEO GENERATION (N8N Project)
# ==========================================

# FFmpeg binary paths (required for Hostinger/shared hosting)
# Get paths by running: which ffmpeg && which ffprobe
FFMPEG_PATH=/home/YOUR_USERNAME/bin/ffmpeg
FFPROBE_PATH=/home/YOUR_USERNAME/bin/ffprobe

# Font for text overlays - REQUIRED for Hindi/Emoji support
# Download Noto Sans Devanagari: https://fonts.google.com/noto/specimen/Noto+Sans+Devanagari
# Upload to your server and set the path here
# Common Linux font paths:
#   /usr/share/fonts/truetype/noto/NotoSans-Regular.ttf
#   /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
# For Hindi + Emoji, download and upload NotoSansDevanagari-Regular.ttf
FFMPEG_FONT_PATH=/home/YOUR_USERNAME/fonts/NotoSansDevanagari-Regular.ttf

# Public video storage (for Instagram posting etc.)
# Videos saved here will be accessible via PUBLIC_VIDEO_URL
PUBLIC_VIDEO_DIR=/home/YOUR_USERNAME/public_html/videos
PUBLIC_VIDEO_URL=https://yourdomain.com/videos
